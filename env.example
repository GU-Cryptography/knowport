# =============================================================================
# 知港 KnowPort - 环境变量模板
# =============================================================================
#
# 使用方法：
#   cp env.example .env
#   # 然后编辑 .env，把所有 CHANGE_ME 替换成你自己的值
#   docker compose up -d
#
# 真实的 .env 文件已加进 .gitignore，永远不会被推到 GitHub。
# 这份 env.example 是给所有部署者作参考的模板。
#
# =============================================================================
# 必填项（CHANGE_ME 的都必须改）
# =============================================================================

# JWT 签名密钥。生产环境务必随机生成，不要用默认值。
# 生成方法： openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_RANDOM_48_BYTES

# 用户级 API Key 落盘加密密钥（AES-GCM）。前端用户填的 OpenAI/Ollama 等模型 Key
# 会用这把密钥加密后写进 auth.db。
# 注意：这把密钥一旦设置后丢失，所有用户存的 API Key 都解不出来。务必备份。
# 生成方法： openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_32_BYTES

# Embedding 向量维度。必须与你前端设置面板里选的 embedding 模型实际输出维度一致：
#   bge-m3              -> 1024
#   nomic-embed-text    -> 768
#   text-embedding-3-*  -> 1536 或 3072
# Qdrant collection 在第一次创建时按这个维度建，之后改维度需要清掉 qdrant 数据卷
QDRANT_VECTOR_SIZE=1024

# =============================================================================
# 可选项
# =============================================================================

# 本机宿主 Ollama 地址，容器走 host-gateway 访问宿主网络
# - macOS / Windows Docker Desktop：使用默认 host.docker.internal 即可
# - Linux 若 host-gateway 不可用：改成 http://<宿主LAN IP>:11434，并让 Ollama 监听 0.0.0.0
# 不用 Ollama 只用 OpenAI 兼容服务的话，这条留空也行（用户会从前端设置面板填）
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Qdrant API Key。如果你给 Qdrant 加了认证就填这里；默认部署不需要
QDRANT_API_KEY=
